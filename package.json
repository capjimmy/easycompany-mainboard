{
  "name": "easycompany-mainboard",
  "version": "1.0.0",
  "description": "이지컨설턴트 업무 효율화 솔루션 메인보드",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node start-electron.js",
    "build": "node build.js",
    "build:tsc": "tsc",
    "start": "npm run build && npm run dev",
    "package": "npm run build && electron-builder"
  },
  "author": "KOC",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "electron-store": "^8.1.0",
    "openai": "^6.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "uuid": "^9.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.koc.easycompany",
    "productName": "EasyCompany Mainboard",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
